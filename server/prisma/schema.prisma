generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Receipt {
  id            String   @id @default(cuid())
  accessKey     String   @unique
  storeName     String?
  storeCnpj     String?
  storeAddress  String?
  issueDate     DateTime?
  total         Float?
  paymentMethod String?
  rawHtml       String
  createdAt     DateTime @default(now())
  items         Item[]
}

model Item {
  id          String  @id @default(cuid())
  receiptId   String
  receipt     Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  description String
  quantity    Float?
  unit        String?
  unitPrice   Float?
  totalPrice  Float?
  category    String?
}
